# Salin file ini ke `.env` dan isi semua nilai sebelum menjalankan app.
# `.env` JANGAN di-commit ke GitHub (sudah di-ignore).

# === Firebase Config ===
# Ambil dari: Firebase Console → Project Settings → General → Your apps → Web App
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# === Google Sign-In ===
# Ambil dari: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Pakai tipe "Web application" client ID (bukan iOS/Android), karena Firebase Auth memakainya
# untuk verifikasi token dari Google Sign-In native module.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# === Domain & App Identity ===
EXPO_PUBLIC_ALLOWED_EMAIL_DOMAIN=student.unu-jogja.ac.id
EXPO_PUBLIC_APP_NAME=Cari.In
EXPO_PUBLIC_APP_ENV=development
