# Salin file ini ke `.env` dan isi semua nilai sebelum menjalankan app.
# `.env` JANGAN di-commit ke GitHub (sudah di-ignore).

# === Supabase Config ===
# Ambil dari: Supabase Dashboard → Project Settings → API
# Project URL (format: https://<project-id>.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_...). JANGAN pakai secret key di sini —
# secret key bypass RLS dan TIDAK boleh di-bundle ke client app.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# === Domain & App Identity ===
EXPO_PUBLIC_ALLOWED_EMAIL_DOMAIN=student.unu-jogja.ac.id
EXPO_PUBLIC_APP_NAME=Cari.In
EXPO_PUBLIC_APP_ENV=development
